generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id            String   @id @default(uuid()) @map("id")
  nim           String   @unique
  name          String
  studyProgram  String   @map("study_program")
  academicYear  String   @map("academic_year")
  phone         String?
  email         String?
  isActive      Boolean  @default(true) @map("is_active")
  photoUrl      String?  @map("photo_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  faceVectors   FaceVector[]
  attendanceLogs AttendanceLog[]
  permits       Permit[]
  violations    Violation[]
  courseSchedules CourseSchedule[]
  permitQuotas  PermitQuota[]

  @@map("students")
}

model FaceVector {
  studentId String   @map("student_id")
  pose      String   // pose name: CENTER, LEFT, RIGHT, UP, DOWN
  vector    Unsupported("vector(192)")
  updatedAt DateTime @updatedAt @map("updated_at")

  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([studentId, pose])
  @@map("face_vectors")
}

model Admin {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  role         String   @default("admin")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  auditLogs    AuditLog[]
  syncRequests SyncRequest[]
  permits      Permit[]

  @@map("admins")
}

model AttendanceLog {
  id              String   @id @default(uuid())
  studentId       String   @map("student_id")
  studentName     String   @map("student_name")
  action          String
  timestamp       DateTime
  confidenceScore Float    @map("confidence_score")
  isViolation     Boolean  @default(false) @map("is_violation")
  violationType   String?  @map("violation_type")
  deviceId        String?  @map("device_id")
  photoCapture    String?  @map("photo_capture")
  isSynced        Boolean  @default(true) @map("is_synced")
  createdAt       DateTime @default(now()) @map("created_at")

  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([timestamp])
  @@index([action])
  @@map("attendance_logs")
}

model Permit {
  id              String    @id @default(uuid())
  studentId       String    @map("student_id")
  type            String
  startDate       DateTime  @map("start_date")
  endDate         DateTime  @map("end_date")
  startTime       String?   @map("start_time")
  endTime         String?   @map("end_time")
  status          String    @default("pending")
  reason          String?
  attachmentUrl   String?   @map("attachment_url")
  approvedById    String?   @map("approved_by_id")
  approvedAt      DateTime? @map("approved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  approvedBy      Admin?    @relation(fields: [approvedById], references: [id])

  @@index([studentId])
  @@index([status])
  @@index([type])
  @@map("permits")
}

model PermitQuota {
  id          String @id @default(uuid())
  studentId   String @map("student_id")
  month       Int
  year        Int
  permitsUsed Int    @default(0) @map("permits_used")
  maxPermits  Int    @default(10) @map("max_permits")

  student     Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, month, year])
  @@map("permit_quotas")
}

model CampusRule {
  id            String  @id @default(uuid())
  dayOfWeek      Int     @map("day_of_week")
  startTime     String  @map("start_time")
  endTime       String  @map("end_time")
  isRestricted  Boolean @default(true) @map("is_restricted")
  appliesToAll  Boolean @default(true) @map("applies_to_all")
  studyProgram  String? @map("study_program")
  academicYear  String? @map("academic_year")
  priority      Int     @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([dayOfWeek])
  @@map("campus_rules")
}

model GlobalSetting {
  key         String @id
  value       String
  description String?

  @@map("global_settings")
}

model CourseSchedule {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  courseName  String   @map("course_name")
  dayOfWeek   Int      @map("day_of_week")
  startTime   String   @map("start_time")
  endTime     String   @map("end_time")
  room        String?
  lecturer    String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, dayOfWeek])
  @@map("course_schedules")
}

model Violation {
  id              String    @id @default(uuid())
  studentId       String    @map("student_id")
  type            String
  description     String?
  action          String?
  timestamp       DateTime
  relatedRuleId   String?   @map("related_rule_id")
  relatedPermitId String?   @map("related_permit_id")
  isResolved      Boolean   @default(false) @map("is_resolved")
  resolvedAt      DateTime? @map("resolved_at")
  resolvedNote    String?   @map("resolved_note")
  createdAt       DateTime  @default(now()) @map("created_at")

  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([type])
  @@index([timestamp])
  @@map("violations")
}

model Device {
  deviceId    String    @id @map("device_id")
  username    String    @unique
  passwordHash String   @map("password_hash")
  name        String
  location    String?
  isActive    Boolean   @default(true) @map("is_active")
  lastPingAt  DateTime? @map("last_ping_at")
  batteryLevel Float?   @map("battery_level")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  syncRequests SyncRequest[]
  syncLogs     SyncLog[]

  @@index([username])
  @@map("devices")
}

model SyncRequest {
  id          String   @id @default(uuid())
  deviceId    String   @map("device_id")
  requestedAt DateTime @default(now()) @map("requested_at")
  isProcessed Boolean  @default(false) @map("is_processed")
  processedAt DateTime? @map("processed_at")
  requestedById String? @map("requested_by_id")

  device      Device   @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)
  requestedBy Admin?   @relation(fields: [requestedById], references: [id])

  @@map("sync_requests")
}

model SyncLog {
  id        String   @id @default(uuid())
  deviceId  String   @map("device_id")
  syncType  String   @map("sync_type")
  status    String
  logsCount Int      @default(0) @map("logs_count")
  createdAt DateTime @default(now()) @map("created_at")

  device    Device   @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)

  @@map("sync_logs")
}

model AuditLog {
  id          String   @id @default(uuid())
  adminId     String   @map("admin_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  details     String?
  createdAt   DateTime @default(now()) @map("created_at")

  admin       Admin    @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

model ImportBatch {
  id          String   @id @default(uuid())
  filename    String
  totalRows   Int      @map("total_rows")
  successRows Int      @map("success_rows")
  failedRows  Int      @map("failed_rows")
  errors      String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("import_batches")
}

model Notification {
  id          String   @id @default(uuid())
  adminId     String?  @map("admin_id")
  type        String
  title       String
  message     String
  isRead      Boolean  @default(false) @map("is_read")
  linkTo      String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([adminId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Holiday {
  id          String   @id @default(uuid())
  name        String
  date        DateTime
  type        String   @default("national")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([date])
  @@index([date])
  @@map("holidays")
}

model ScanMetric {
  id                String   @id @default(uuid())
  studentId         String   @map("student_id")
  predictedStudentId String? @map("predicted_student_id")
  deviceId          String?  @map("device_id")
  matchingTimeMs    Int      @default(0) @map("matching_time_ms")
  totalTimeMs       Int      @default(0) @map("total_time_ms")
  decision          String   @map("decision")  // CONFIDENT / MEDIUM / WEAK / NO_MATCH
  topSimilarity     Float    @map("top_similarity")
  gap               Float    @default(0) @map("gap")
  runnerUpSimilarity Float   @default(0) @map("runner_up_similarity")
  isCorrect         Boolean? @map("is_correct")  // null until admin reviews
  reviewedById      String?  @map("reviewed_by_id")
  reviewedAt        DateTime? @map("reviewed_at")
  note              String?  @map("note")
  timestamp         DateTime @default(now()) @map("timestamp")

  @@index([studentId])
  @@index([deviceId])
  @@index([decision])
  @@index([timestamp])
  @@map("scan_metrics")
}

model DailyMetrics {
  id               String  @id @default(uuid())
  date             DateTime @unique
  totalScans       Int     @default(0) @map("total_scans")
  totalConfident   Int     @default(0) @map("total_confident")
  totalMedium      Int     @default(0) @map("total_medium")
  totalWeak        Int     @default(0) @map("total_weak")
  totalNoMatch     Int     @default(0) @map("total_no_match")
  falsePositives   Int     @default(0) @map("false_positives")
  falseNegatives   Int     @default(0) @map("false_negatives")
  avgResponseTimeMs Float  @default(0) @map("avg_response_time_ms")
  fpr              Float   @default(0)  // False Positive Rate
  fnr              Float   @default(0)  // False Negative Rate
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("daily_metrics")
}
